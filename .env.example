# Telegram-бот для уведомлений о заявках
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Админ-панель: логин и пароль
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# API-ключ для внешних интеграций (Telegram-бот и т.д.)
