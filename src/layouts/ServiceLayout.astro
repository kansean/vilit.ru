---
import PageLayout from './PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import FullRequestForm from '../components/forms/FullRequestForm.astro';
import InlineLeadForm from '../components/forms/InlineLeadForm.astro';
import JsonLdService from '../components/seo/JsonLdService.astro';
import JsonLdFAQ from '../components/seo/JsonLdFAQ.astro';
import { buildBreadcrumbs } from '../utils/breadcrumbs';

interface Props {
  title: string;
  description: string;
  metaTitle: string;
  metaDescription: string;
  heroTitle: string;
  heroSubtitle: string;
  icon: string;
  price?: string;
  priceNote?: string;
  features?: string[];
  steps?: { title: string; description: string }[];
  faq?: { question: string; answer: string }[];
  slug: string;
  relatedServices?: string[];
  relatedIndustries?: string[];
  contentHtml?: string;
}

const {
  title, description, metaTitle, metaDescription,
  heroTitle, heroSubtitle, icon, price, priceNote,
  features, steps, faq, slug, relatedServices, relatedIndustries,
  contentHtml,
} = Astro.props;

const breadcrumbs = buildBreadcrumbs(`/uslugi/${slug}`, title);
---

<PageLayout title={metaTitle} description={metaDescription}>
  <JsonLdService name={title} description={description} url={`/uslugi/${slug}`} price={price} />
  {faq && faq.length > 0 && <JsonLdFAQ items={faq} />}

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-900 to-primary-700 text-white py-16 lg:py-24">
      <Container>
        <Breadcrumbs items={breadcrumbs} />
        <div class="max-w-3xl">
          <div class="text-5xl mb-4">{icon}</div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">{heroTitle}</h1>
          <p class="text-lg text-primary-100 mb-6">{heroSubtitle}</p>
          {price && (
            <div class="inline-flex items-baseline gap-2 bg-white/10 rounded-xl px-6 py-3 backdrop-blur-sm">
              <span class="text-2xl font-bold">{price}</span>
              {priceNote && <span class="text-primary-200 text-sm">{priceNote}</span>}
            </div>
          )}
        </div>
      </Container>
    </section>

    <!-- Content -->
    <section class="section">
      <Container>
        <div class="max-w-3xl prose">
          {contentHtml ? <Fragment set:html={contentHtml} /> : <slot />}
        </div>
      </Container>
    </section>

    <!-- Features -->
    {features && features.length > 0 && (
      <section class="pb-16">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Что входит в услугу</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {features.map((feature) => (
              <div class="flex items-start gap-3 p-4 bg-primary-50 rounded-xl">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-neutral-800">{feature}</span>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Steps -->
    {steps && steps.length > 0 && (
      <section class="section bg-neutral-50">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Как это работает</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {steps.map((step, i) => (
              <div class="relative">
                <div class="text-4xl font-bold text-primary-100 mb-3">{String(i + 1).padStart(2, '0')}</div>
                <h3 class="text-lg font-bold text-neutral-900 mb-2">{step.title}</h3>
                <p class="text-sm text-neutral-600">{step.description}</p>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Inline Lead Form -->
    <section class="py-12">
      <Container>
        <InlineLeadForm title={`Нужна помощь с ${title.toLowerCase()}?`} />
      </Container>
    </section>

    <!-- FAQ -->
    {faq && faq.length > 0 && (
      <section class="section">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Частые вопросы</h2>
          <div class="max-w-3xl">
            <FAQAccordion items={faq} />
          </div>
        </Container>
      </section>
    )}

    <!-- Full Request Form -->
    <section class="section bg-neutral-50">
      <Container>
        <FullRequestForm title={`Заказать: ${title}`} />
      </Container>
    </section>
  </main>
</PageLayout>
