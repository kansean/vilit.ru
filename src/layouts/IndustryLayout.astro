---
import PageLayout from './PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import FullRequestForm from '../components/forms/FullRequestForm.astro';
import InlineLeadForm from '../components/forms/InlineLeadForm.astro';
import JsonLdFAQ from '../components/seo/JsonLdFAQ.astro';
import { buildBreadcrumbs } from '../utils/breadcrumbs';

interface Props {
  title: string;
  description: string;
  metaTitle: string;
  metaDescription: string;
  heroTitle: string;
  heroSubtitle: string;
  icon: string;
  painPoints?: string[];
  legalRequirements?: string[];
  equipment?: string[];
  faq?: { question: string; answer: string }[];
  slug: string;
  relatedServices?: string[];
  contentHtml?: string;
}

const {
  title, description, metaTitle, metaDescription,
  heroTitle, heroSubtitle, icon,
  painPoints, legalRequirements, equipment,
  faq, slug, relatedServices, contentHtml,
} = Astro.props;

const breadcrumbs = buildBreadcrumbs(`/dlya-biznesa/${slug}`, title);
---

<PageLayout title={metaTitle} description={metaDescription}>
  {faq && faq.length > 0 && <JsonLdFAQ items={faq} />}

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-900 to-primary-700 text-white py-16 lg:py-24">
      <Container>
        <Breadcrumbs items={breadcrumbs} />
        <div class="max-w-3xl">
          <div class="text-5xl mb-4">{icon}</div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">{heroTitle}</h1>
          <p class="text-lg text-primary-100">{heroSubtitle}</p>
        </div>
      </Container>
    </section>

    <!-- Pain Points -->
    {painPoints && painPoints.length > 0 && (
      <section class="section">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Знакомые проблемы?</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {painPoints.map((point) => (
              <div class="flex items-start gap-3 p-4 bg-red-50 rounded-xl border border-red-100">
                <svg class="w-5 h-5 text-red-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
                <span class="text-neutral-800">{point}</span>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Legal Requirements -->
    {legalRequirements && legalRequirements.length > 0 && (
      <section class="section bg-neutral-50">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Что требуется по закону</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {legalRequirements.map((req) => (
              <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-neutral-200">
                <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-neutral-800">{req}</span>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Content -->
    <section class="section">
      <Container>
        <div class="max-w-3xl prose">
          {contentHtml ? <Fragment set:html={contentHtml} /> : <slot />}
        </div>
      </Container>
    </section>

    <!-- Equipment -->
    {equipment && equipment.length > 0 && (
      <section class="section bg-neutral-50">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Что мы подберём</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {equipment.map((item) => (
              <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-neutral-200">
                <svg class="w-5 h-5 text-green-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-neutral-800">{item}</span>
              </div>
            ))}
          </div>
        </Container>
      </section>
    )}

    <!-- Inline Lead Form -->
    <section class="py-12">
      <Container>
        <InlineLeadForm title={`Автоматизация для ${title.toLowerCase()}: получите расчёт`} />
      </Container>
    </section>

    <!-- FAQ -->
    {faq && faq.length > 0 && (
      <section class="section">
        <Container>
          <h2 class="text-2xl font-bold text-neutral-900 mb-8">Частые вопросы</h2>
          <div class="max-w-3xl">
            <FAQAccordion items={faq} />
          </div>
        </Container>
      </section>
    )}

    <!-- Full Request Form -->
    <section class="section bg-neutral-50">
      <Container>
        <FullRequestForm title={`Заявка на автоматизацию: ${title}`} />
      </Container>
    </section>
  </main>
</PageLayout>
