---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/ui/Container.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import FullRequestForm from '../components/forms/FullRequestForm.astro';
import JsonLdLocalBusiness from '../components/seo/JsonLdLocalBusiness.astro';
import { buildBreadcrumbs } from '../utils/breadcrumbs';
import { company } from '../data/company';

const breadcrumbs = buildBreadcrumbs('/kontakty', 'Контакты');
---

<PageLayout title="Контакты" description={`Контакты компании «Вилит». Телефон: ${company.phone}, email: ${company.email}. Адрес: ${company.address.full}.`}>
  <JsonLdLocalBusiness />

  <main>
    <section class="bg-gradient-to-br from-primary-900 to-primary-700 text-white py-16">
      <Container>
        <Breadcrumbs items={breadcrumbs} />
        <h1 class="text-3xl sm:text-4xl font-bold mb-4">Контакты</h1>
        <p class="text-lg text-primary-100">Свяжитесь с нами удобным способом</p>
      </Container>
    </section>

    <section class="section">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl font-bold text-neutral-900 mb-8">Наши реквизиты</h2>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-neutral-900 mb-1">Телефон</div>
                  <a href={`tel:${company.phoneRaw}`} class="text-primary-600 text-lg font-medium hover:text-primary-700">{company.phone}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-neutral-900 mb-1">Email</div>
                  <a href={`mailto:${company.email}`} class="text-primary-600 hover:text-primary-700">{company.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-neutral-900 mb-1">Адрес</div>
                  <p class="text-neutral-600">{company.address.full}</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-neutral-900 mb-1">Режим работы</div>
                  <p class="text-neutral-600">{company.workingHours}</p>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-8 border-t border-neutral-200">
              <h3 class="font-semibold text-neutral-900 mb-3">Юридическая информация</h3>
              <div class="text-sm text-neutral-600 space-y-1">
                <p>{company.legalName}</p>
                <p>ИНН: {company.inn}</p>
                <p>ОГРН: {company.ogrn}</p>
              </div>
            </div>
          </div>

          <!-- Form -->
          <div>
            <FullRequestForm title="Напишите нам" />
          </div>
        </div>
      </Container>
    </section>

    <!-- Яндекс.Карта (embed — без API-ключа) -->
    <!-- Чтобы обновить: откройте yandex.ru/maps, найдите адрес, нажмите "Поделиться" → "Код для вставки" и замените src ниже -->
    <section class="pb-16">
      <Container>
        <div class="rounded-2xl overflow-hidden h-80">
          <iframe
            src="https://yandex.ru/map-widget/v1/?ll=37.617700%2C55.755864&z=15&l=map"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            title="Офис Вилит на карте"
          ></iframe>
        </div>
      </Container>
    </section>
  </main>
</PageLayout>
