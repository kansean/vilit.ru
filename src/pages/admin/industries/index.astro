---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { industriesRepo } from '../../../lib/industries.repo';

const industries = industriesRepo.list();
---

<AdminLayout title="Отрасли">
  <div class="flex-between">
    <p class="text-muted">{industries.length} отраслей</p>
    <a href="/admin/industries/new" class="btn btn-primary">+ Создать</a>
  </div>

  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>Slug</th>
        <th>Порядок</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {industries.map((s) => (
        <tr>
          <td>
            <strong>{s.title}</strong>
            <div class="text-sm text-muted">{s.icon}</div>
          </td>
          <td class="text-sm">{s.id}</td>
          <td class="text-sm">{s.sort_order}</td>
          <td>
            <div class="actions">
              <a href={`/admin/industries/${s.id}`} class="btn btn-secondary btn-sm">Редактировать</a>
              <a href={`/dlya-biznesa/${s.id}`} class="btn btn-secondary btn-sm" target="_blank">Просмотр</a>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
