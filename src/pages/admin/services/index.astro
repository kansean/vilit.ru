---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { servicesRepo } from '../../../lib/services.repo';

const services = servicesRepo.list();
---

<AdminLayout title="Услуги">
  <div class="flex-between">
    <p class="text-muted">{services.length} услуг</p>
    <a href="/admin/services/new" class="btn btn-primary">+ Создать</a>
  </div>

  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>Slug</th>
        <th>Цена</th>
        <th>Порядок</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {services.map((s) => (
        <tr>
          <td>
            <strong>{s.title}</strong>
            <div class="text-sm text-muted">{s.icon}</div>
          </td>
          <td class="text-sm">{s.id}</td>
          <td class="text-sm">{s.price || '—'}</td>
          <td class="text-sm">{s.sort_order}</td>
          <td>
            <div class="actions">
              <a href={`/admin/services/${s.id}`} class="btn btn-secondary btn-sm">Редактировать</a>
              <a href={`/uslugi/${s.id}`} class="btn btn-secondary btn-sm" target="_blank">Просмотр</a>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
