---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { servicesRepo } from '../../../lib/services.repo';
import { safeJsonParse } from '../../../lib/safe-json';

const { id } = Astro.params;
const isNew = id === 'new';
const item = isNew ? null : servicesRepo.getById(id!);

if (!isNew && !item) {
  return Astro.redirect('/admin/services');
}

const title = isNew ? 'Новая услуга' : `Редактирование: ${item!.title}`;

const formData = isNew ? {
  id: '', title: '', description: '', meta_title: '', meta_description: '',
  icon: '', hero_title: '', hero_subtitle: '', price: '', price_note: '',
  sort_order: 0, features: [] as string[], steps: [] as {title:string;description:string}[], faq: [] as {question:string;answer:string}[],
  related_services: [] as string[], related_industries: [] as string[], content: ''
} : {
  ...item,
  features: safeJsonParse<string[]>(item!.features, []),
  steps: safeJsonParse<{title:string;description:string}[]>(item!.steps, []),
  faq: safeJsonParse<{question:string;answer:string}[]>(item!.faq, []),
  related_services: safeJsonParse<string[]>(item!.related_services, []),
  related_industries: safeJsonParse<string[]>(item!.related_industries, []),
};
---

<AdminLayout title={title}>
  <div x-data={`serviceForm(${JSON.stringify(formData)})`}>

    <div class="flex-between">
      <a href="/admin/services" class="btn btn-secondary btn-sm">← Назад</a>
      <div class="actions">
        {!isNew && (
          <button class="btn btn-danger btn-sm" @click="deleteItem()">Удалить</button>
        )}
        <button class="btn btn-primary" @click="save()" :disabled="saving">
          <span x-show="!saving">Сохранить</span>
          <span x-show="saving">Сохранение...</span>
        </button>
      </div>
    </div>

    <div class="grid-2 mt-4">
      <div>
        <div class="card">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Основное</h3>

          {isNew && (
            <div class="form-group">
              <label>Slug (id)</label>
              <input type="text" x-model="form.id" placeholder="markirovka" />
              <div class="help">Латиница, дефисы. Используется в URL: /uslugi/slug</div>
            </div>
          )}

          <div class="form-group">
            <label>Название</label>
            <input type="text" x-model="form.title" />
          </div>

          <div class="form-group">
            <label>Описание (краткое)</label>
            <textarea x-model="form.description" rows="2"></textarea>
          </div>

          <div class="form-group">
            <label>Иконка (emoji)</label>
            <input type="text" x-model="form.icon" />
          </div>

          <div class="grid-2">
            <div class="form-group">
              <label>Цена</label>
              <input type="text" x-model="form.price" placeholder="от 5 000 ₽" />
            </div>
            <div class="form-group">
              <label>Прим. к цене</label>
              <input type="text" x-model="form.price_note" placeholder="за подключение" />
            </div>
          </div>

          <div class="form-group">
            <label>Порядок сортировки</label>
            <input type="number" x-model.number="form.sort_order" />
          </div>
        </div>

        <div class="card mt-4">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">SEO</h3>
          <div class="form-group">
            <label>Meta Title</label>
            <input type="text" x-model="form.meta_title" />
          </div>
          <div class="form-group">
            <label>Meta Description</label>
            <textarea x-model="form.meta_description" rows="2"></textarea>
          </div>
          <div class="form-group">
            <label>Hero Title</label>
            <input type="text" x-model="form.hero_title" />
          </div>
          <div class="form-group">
            <label>Hero Subtitle</label>
            <textarea x-model="form.hero_subtitle" rows="2"></textarea>
          </div>
        </div>
      </div>

      <div>
        <div class="card">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Особенности</h3>
          <template x-for="(f, i) in form.features" :key="i">
            <div class="array-item">
              <input type="text" x-model="form.features[i]" />
              <button @click="form.features.splice(i, 1)">×</button>
            </div>
          </template>
          <button class="btn btn-secondary btn-sm" @click="form.features.push('')">+ Добавить</button>
        </div>

        <div class="card mt-4">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Этапы</h3>
          <template x-for="(s, i) in form.steps" :key="i">
            <div class="faq-item">
              <input type="text" x-model="form.steps[i].title" placeholder="Название" />
              <textarea x-model="form.steps[i].description" rows="2" placeholder="Описание"></textarea>
              <button class="btn btn-danger btn-sm" @click="form.steps.splice(i, 1)">Удалить</button>
            </div>
          </template>
          <button class="btn btn-secondary btn-sm" @click="form.steps.push({title:'',description:''})">+ Добавить этап</button>
        </div>

        <div class="card mt-4">
          <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">FAQ</h3>
          <template x-for="(f, i) in form.faq" :key="i">
            <div class="faq-item">
              <input type="text" x-model="form.faq[i].question" placeholder="Вопрос" />
              <textarea x-model="form.faq[i].answer" rows="2" placeholder="Ответ"></textarea>
              <button class="btn btn-danger btn-sm" @click="form.faq.splice(i, 1)">Удалить</button>
            </div>
          </template>
          <button class="btn btn-secondary btn-sm" @click="form.faq.push({question:'',answer:''})">+ Добавить</button>
        </div>
      </div>
    </div>

    <div class="card mt-4">
      <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Контент (Markdown)</h3>
      <div class="form-group">
        <textarea x-model="form.content" rows="15" style="font-family: monospace; font-size: 0.8125rem;"></textarea>
      </div>
    </div>

    <div class="card mt-4">
      <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1rem;">Связи</h3>
      <div class="grid-2">
        <div class="form-group">
          <label>Связанные услуги (slug через запятую)</label>
          <input type="text" :value="form.related_services.join(', ')"
            @change="form.related_services = $event.target.value.split(',').map(s => s.trim()).filter(Boolean)" />
        </div>
        <div class="form-group">
          <label>Связанные отрасли (slug через запятую)</label>
          <input type="text" :value="form.related_industries.join(', ')"
            @change="form.related_industries = $event.target.value.split(',').map(s => s.trim()).filter(Boolean)" />
        </div>
      </div>
    </div>

    <div style="margin-top: 1rem; text-align: right;">
      <button class="btn btn-primary" @click="save()" :disabled="saving">
        <span x-show="!saving">Сохранить</span>
        <span x-show="saving">Сохранение...</span>
      </button>
    </div>
  </div>

  <script is:inline define:vars={{ isNew, itemId: isNew ? '' : id }}>
    function serviceForm(initial) {
      return {
        form: initial,
        saving: false,
        async save() {
          this.saving = true;
          try {
            const body = {
              ...this.form,
              features: JSON.stringify(this.form.features.filter(Boolean)),
              steps: JSON.stringify(this.form.steps.filter(s => s.title)),
              faq: JSON.stringify(this.form.faq.filter(f => f.question)),
              related_services: JSON.stringify(this.form.related_services),
              related_industries: JSON.stringify(this.form.related_industries),
            };

            const url = isNew ? '/api/v1/services' : `/api/v1/services/${itemId}`;
            const method = isNew ? 'POST' : 'PUT';
            const res = await fetch(url, {
              method,
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });

            if (res.ok) {
              const data = await res.json();
              if (isNew) {
                window.location.href = `/admin/services/${data.item.id}`;
              } else {
                alert('Сохранено!');
              }
            } else {
              const err = await res.json();
              alert('Ошибка: ' + (err.error || 'Неизвестная ошибка'));
            }
          } catch (e) {
            alert('Ошибка сети');
          } finally {
            this.saving = false;
          }
        },
        async deleteItem() {
          if (!confirm('Удалить услугу? Это действие нельзя отменить.')) return;
          const res = await fetch(`/api/v1/services/${itemId}`, { method: 'DELETE' });
          if (res.ok) {
            window.location.href = '/admin/services';
          } else {
            alert('Ошибка удаления');
          }
        },
      };
    }
  </script>
</AdminLayout>
