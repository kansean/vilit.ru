---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { equipmentRepo } from '../../../lib/equipment.repo';
import { categoryLabelsShort } from '../../../data/categories';

const equipment = equipmentRepo.list();
---

<AdminLayout title="Оборудование">
  <div class="flex-between">
    <p class="text-muted">{equipment.length} товаров</p>
    <a href="/admin/equipment/new" class="btn btn-primary">+ Создать</a>
  </div>

  <table>
    <thead>
      <tr>
        <th>Название</th>
        <th>Категория</th>
        <th>Цена</th>
        <th>Наличие</th>
        <th>Действия</th>
      </tr>
    </thead>
    <tbody>
      {equipment.map((e) => (
        <tr>
          <td>
            <strong>{e.title}</strong>
            <div class="text-sm text-muted">{e.brand} {e.model}</div>
          </td>
          <td class="text-sm">{categoryLabelsShort[e.category] || e.category}</td>
          <td class="text-sm">{e.price.toLocaleString('ru-RU')} ₽</td>
          <td>
            <span class={`badge ${e.in_stock ? 'badge-done' : 'badge-processing'}`}>
              {e.in_stock ? 'В наличии' : 'Под заказ'}
            </span>
          </td>
          <td>
            <div class="actions">
              <a href={`/admin/equipment/${e.id}`} class="btn btn-secondary btn-sm">Редактировать</a>
              <a href={`/oborudovanie/${e.category}/${e.id}`} class="btn btn-secondary btn-sm" target="_blank">Просмотр</a>
            </div>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</AdminLayout>
