---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/ui/Container.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import FAQAccordion from '../../components/ui/FAQAccordion.astro';
import InlineLeadForm from '../../components/forms/InlineLeadForm.astro';
import FullRequestForm from '../../components/forms/FullRequestForm.astro';
import JsonLdService from '../../components/seo/JsonLdService.astro';
import JsonLdFAQ from '../../components/seo/JsonLdFAQ.astro';
import { buildBreadcrumbs } from '../../utils/breadcrumbs';

const title = 'Аренда онлайн-касс LiteBox';
const breadcrumbs = buildBreadcrumbs('/uslugi/arenda-kkt', title);

const models = [
  {
    name: 'LiteBox 5',
    image: '/images/arenda/litebox-5.jpg',
    description: 'Компактная мобильная касса. Встроенный принтер чеков, сенсорный экран 5.5". Идеальна для курьеров, выездной торговли и небольших точек.',
    price: '1 990',
  },
  {
    name: 'LiteBox 5A',
    image: '/images/arenda/litebox-5a.jpg',
    description: 'Мобильная касса с расширенными возможностями. Сенсорный экран 5.5", встроенный принтер, поддержка эквайринга.',
    price: '2 190',
  },
  {
    name: 'LiteBox 5 Pro',
    image: '/images/arenda/litebox-5-pro.jpg',
    description: 'Профессиональная мобильная касса. Повышенная производительность, встроенный принтер чеков, экран 5.5".',
    price: '1 990',
  },
  {
    name: 'LiteBox 7',
    image: '/images/arenda/litebox-7.jpg',
    description: 'Стационарная касса с большим экраном 7". Встроенный принтер чеков. Оптимальна для магазинов, кафе и салонов.',
    price: '2 240',
  },
];

const tariffs = [
  { equipment: 'LiteBox 5', price: '1 990' },
  { equipment: 'LiteBox 7', price: '2 240' },
  { equipment: 'LiteBox 5A', price: '2 190' },
  { equipment: 'LiteBox 5 PRO', price: '1 990' },
  { equipment: 'LiteBox 7 + Сканер 2D Атол SB 2108 USB', price: '2 440' },
  { equipment: 'LiteBox 5 + Эквайринг D 200', price: '2 190' },
  { equipment: 'LiteBox 7 + Эквайринг D 200', price: '2 440' },
  { equipment: 'LiteBox 7 + Сканер 2D Атол SB 2108 USB + Эквайринг D 200', price: '2 640' },
];

const included = [
  'Кассовое оборудование (онлайн-касса и/или эквайринг)',
  'Замена ФН (фискальный накопитель приобретается отдельно)',
  'Договор с ОФД на 1 год (в первый год сотрудничества)',
  'Регистрация кассы в ОФД и ФНС (в первый год сотрудничества)',
  'Перерегистрация кассы в ОФД и ФНС ежегодно, включая договор с ОФД',
  'Установка, настройка и тестирование кассового оборудования',
  'Подключение POS-терминала при наличии договора эквайринга',
  '«Горячая замена» кассового оборудования',
  'Инструктаж о порядке работы с кассовым оборудованием',
  'Кассовое ПО + товароучётная система',
  'Сервисное обслуживание и техническая поддержка',
  'Консультация по работе с продуктами LiteBox',
];

const advantages = [
  { icon: '💰', title: 'Нет капитальных затрат', description: 'Не нужно покупать кассу — платите только ежемесячную абонентскую плату' },
  { icon: '📦', title: 'Всё включено', description: 'Касса, ПО, ОФД, регистрация, настройка — в одном тарифе' },
  { icon: '🛠', title: 'Техподдержка 24/7', description: 'Оперативная помощь по телефону и удалённо в любое время' },
  { icon: '🔄', title: 'Замена при поломке', description: '«Горячая замена» оборудования — бизнес не останавливается' },
  { icon: '📈', title: 'Масштабируемость', description: 'Легко добавить или убрать кассы при изменении потребностей' },
  { icon: '🔄', title: 'Актуальное ПО', description: 'Обновления кассового ПО и товароучётной системы включены в тариф' },
];

const steps = [
  { num: '01', title: 'Оставьте заявку', description: 'Заполните форму на сайте или позвоните нам — расскажем о тарифах и поможем выбрать' },
  { num: '02', title: 'Подбор модели', description: 'Подберём оптимальную кассу и комплектацию под ваш тип бизнеса' },
  { num: '03', title: 'Договор и настройка', description: 'Заключаем договор, регистрируем кассу в ФНС, настраиваем и подключаем' },
  { num: '04', title: 'Работайте', description: 'Принимайте оплату и ведите учёт — мы обеспечиваем сервис и поддержку' },
];

const faq = [
  { question: 'На какой срок заключается договор аренды?', answer: 'Минимальный срок договора — 1 год. После этого договор автоматически продлевается на тех же условиях. Вы можете расторгнуть договор, уведомив нас за 30 дней.' },
  { question: 'Что произойдёт, если касса сломается?', answer: 'Мы выполним «горячую замену» — привезём исправную кассу и заберём неисправную. Это входит в тариф и не требует дополнительной оплаты.' },
  { question: 'Можно ли выкупить кассу после аренды?', answer: 'Да, после окончания срока аренды вы можете выкупить оборудование по остаточной стоимости. Условия выкупа уточняйте у менеджера.' },
  { question: 'Фискальный накопитель (ФН) входит в стоимость аренды?', answer: 'ФН приобретается отдельно. Замена ФН по истечении срока действия входит в тариф — мы заменим накопитель и перерегистрируем кассу в ФНС.' },
  { question: 'Входит ли ОФД в стоимость аренды?', answer: 'Да, договор с ОФД на 1 год включён в тариф в первый год сотрудничества. В последующие годы перерегистрация кассы в ОФД также входит в абонентскую плату.' },
  { question: 'Поддерживают ли кассы LiteBox маркировку?', answer: 'Да, кассы LiteBox поддерживают работу с маркированным товаром. Лицензия «Маркировка» подключается как дополнительная опция за 180 руб/мес.' },
  { question: 'Можно ли арендовать несколько касс?', answer: 'Да, вы можете арендовать любое количество касс. Каждая касса оплачивается по отдельному тарифу. При аренде нескольких касс возможны индивидуальные условия.' },
  { question: 'Нужен ли интернет для работы кассы?', answer: 'Для передачи данных в ОФД кассе нужен доступ в интернет. Кассы LiteBox работают через Wi-Fi или мобильный интернет (SIM-карта). При временном отсутствии связи касса сохраняет чеки и отправляет их при восстановлении соединения.' },
];
---

<PageLayout
  title="Аренда онлайн-касс LiteBox — от 1 990 руб/мес"
  description="Аренда онлайн-касс LiteBox для бизнеса: касса + кассовое ПО + ОФД + регистрация в ФНС + сервисное обслуживание. От 1 990 руб/мес с НДС. Горячая замена при поломке."
>
  <JsonLdService name={title} description="Аренда онлайн-касс LiteBox для бизнеса: касса, ПО, ОФД, настройка и сервисная поддержка в одном тарифе" url="/uslugi/arenda-kkt" price="1990" />
  <JsonLdFAQ items={faq} />

  <main>
    <!-- 1. Hero -->
    <section class="bg-gradient-to-br from-primary-900 to-primary-700 text-white py-16 lg:py-24">
      <Container>
        <Breadcrumbs items={breadcrumbs} />
        <div class="max-w-3xl">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4">Аренда онлайн-касс LiteBox</h1>
          <p class="text-lg text-primary-100 mb-6">
            Готовое решение для бизнеса: касса + кассовое ПО + ОФД + регистрация в ФНС + сервисное обслуживание. Никаких капитальных затрат — платите только абонентскую плату.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <div class="inline-flex items-baseline gap-2 bg-white/10 rounded-xl px-6 py-3 backdrop-blur-sm">
              <span class="text-2xl font-bold">от 1 990 ₽/мес</span>
              <span class="text-primary-200 text-sm">с НДС</span>
            </div>
            <a
              href="#zayavka"
              class="inline-flex items-center bg-accent-500 text-white font-semibold px-6 py-3 rounded-lg hover:bg-accent-600 transition-colors"
            >
              Оставить заявку
            </a>
          </div>
        </div>
      </Container>
    </section>

    <!-- 2. Преимущества аренды -->
    <section class="py-16">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Преимущества аренды</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {advantages.map((item) => (
            <div class="bg-primary-50 rounded-xl p-6">
              <div class="text-3xl mb-3">{item.icon}</div>
              <h3 class="text-lg font-bold text-neutral-900 mb-2">{item.title}</h3>
              <p class="text-sm text-neutral-600">{item.description}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- 3. Карточки касс -->
    <section class="py-16 bg-neutral-50">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Модели касс LiteBox</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {models.map((model) => (
            <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
              <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
                <img
                  src={model.image}
                  alt={model.name}
                  class="w-full h-full object-contain p-4"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <h3 class="text-lg font-bold text-neutral-900 mb-2">{model.name}</h3>
                <p class="text-sm text-neutral-600 mb-4">{model.description}</p>
                <div class="flex items-baseline gap-1">
                  <span class="text-xl font-bold text-primary-600">от {model.price} ₽</span>
                  <span class="text-sm text-neutral-500">/мес</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- 4. Таблица тарифов -->
    <section class="py-16">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Тарифы. Абонентская плата</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead>
              <tr class="bg-primary-600 text-white">
                <th class="text-left px-6 py-4 font-semibold rounded-tl-xl">Оборудование</th>
                <th class="text-right px-6 py-4 font-semibold rounded-tr-xl whitespace-nowrap">Цена за месяц, ₽ (с НДС)</th>
              </tr>
            </thead>
            <tbody>
              {tariffs.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-neutral-50'}>
                  <td class="px-6 py-4 text-neutral-800">{row.equipment}</td>
                  <td class="px-6 py-4 text-right font-semibold text-neutral-900 whitespace-nowrap">{row.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-sm text-neutral-500 mt-4">* ФН (фискальный накопитель) приобретается отдельно</p>
      </Container>
    </section>

    <!-- 5. Что входит в тариф -->
    <section class="py-16 bg-neutral-50">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Что входит в тариф «Бизнес»</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {included.map((item) => (
            <div class="flex items-start gap-3 p-4 bg-white rounded-xl">
              <svg class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-neutral-800">{item}</span>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- 6. Дополнительные лицензии -->
    <section class="py-16">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Дополнительные лицензии</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
          <div class="border border-neutral-200 rounded-xl p-6 bg-white">
            <h3 class="text-lg font-bold text-neutral-900 mb-2">Маркировка</h3>
            <p class="text-sm text-neutral-600 mb-4">Работа с маркированными товарами: табак, обувь, одежда, молочная продукция и др.</p>
            <div class="flex items-baseline gap-1">
              <span class="text-xl font-bold text-primary-600">180 ₽</span>
              <span class="text-sm text-neutral-500">/мес</span>
            </div>
          </div>
          <div class="border border-neutral-200 rounded-xl p-6 bg-white">
            <h3 class="text-lg font-bold text-neutral-900 mb-2">ЕГАИС</h3>
            <p class="text-sm text-neutral-600 mb-4">Учёт алкогольной продукции: приёмка, списание, продажа пива и крепкого алкоголя.</p>
            <div class="flex items-baseline gap-1">
              <span class="text-xl font-bold text-primary-600">380 ₽</span>
              <span class="text-sm text-neutral-500">/мес</span>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- 7. Как оформить аренду -->
    <section class="py-16 bg-neutral-50">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8 text-center">Как оформить аренду</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step) => (
            <div class="relative">
              <div class="text-4xl font-bold text-primary-100 mb-3">{step.num}</div>
              <h3 class="text-lg font-bold text-neutral-900 mb-2">{step.title}</h3>
              <p class="text-sm text-neutral-600">{step.description}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- 8. InlineLeadForm -->
    <section class="py-12">
      <Container>
        <InlineLeadForm title="Нужна помощь с выбором кассы?" />
      </Container>
    </section>

    <!-- 9. FAQ -->
    <section class="py-16">
      <Container>
        <h2 class="text-2xl font-bold text-neutral-900 mb-8">Частые вопросы</h2>
        <div class="max-w-3xl">
          <FAQAccordion items={faq} />
        </div>
      </Container>
    </section>

    <!-- 10. FullRequestForm -->
    <section id="zayavka" class="py-16 bg-neutral-50">
      <Container>
        <FullRequestForm title="Заказать аренду кассы" />
      </Container>
    </section>
  </main>
</PageLayout>
