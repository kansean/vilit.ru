---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  price?: string;
}

const { title, description, href, icon, price } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl shadow-sm border border-neutral-100 p-6 hover:shadow-lg hover:border-primary-200 hover:-translate-y-1 transition-all duration-200">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-lg font-bold text-neutral-900 group-hover:text-primary-600 mb-2">{title}</h3>
  <p class="text-neutral-600 text-sm mb-4 line-clamp-2">{description}</p>
  {price && (
    <div class="text-primary-600 font-semibold text-sm">{price}</div>
  )}
  <div class="mt-4 text-primary-600 text-sm font-medium group-hover:translate-x-1 transition-transform duration-200">
    Подробнее →
  </div>
</a>
