---
import { formatPrice } from '../../utils/formatters';

interface Props {
  title: string;
  brand: string;
  price: number;
  oldPrice?: number;
  href: string;
  image?: string;
  inStock?: boolean;
}

const { title, brand, price, oldPrice, href, image, inStock = true } = Astro.props;
---

<a href={href} class="group block bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
  <div class="aspect-square bg-neutral-50 flex items-center justify-center p-6">
    {image ? (
      <img src={image} alt={title} class="max-w-full max-h-full object-contain" />
    ) : (
      <div class="text-5xl text-neutral-300">📦</div>
    )}
  </div>
  <div class="p-4">
    <div class="text-xs text-primary-600 font-medium mb-1">{brand}</div>
    <h3 class="text-sm font-bold text-neutral-900 group-hover:text-primary-600 mb-2 line-clamp-2">{title}</h3>
    <div class="flex items-baseline gap-2">
      <span class="text-lg font-bold text-neutral-900">{formatPrice(price)}</span>
      {oldPrice && (
        <span class="text-sm text-neutral-400 line-through">{formatPrice(oldPrice)}</span>
      )}
    </div>
    <div class="mt-2 flex items-center gap-1.5">
      <span class:list={['w-2 h-2 rounded-full', inStock ? 'bg-green-500' : 'bg-orange-500']}></span>
      <span class="text-xs text-neutral-500">{inStock ? 'В наличии' : 'Под заказ'}</span>
    </div>
  </div>
</a>
