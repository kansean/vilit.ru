---
import Container from '../ui/Container.astro';
import { trustNumbers } from '../../data/trust-numbers';
---

<section class="py-12 bg-white border-y border-neutral-100">
  <Container>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {trustNumbers.map((item) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold text-primary-600 mb-1">{item.value}</div>
          <div class="text-sm font-semibold text-neutral-900 mb-1">{item.label}</div>
          <div class="text-xs text-neutral-500">{item.description}</div>
        </div>
      ))}
    </div>
  </Container>
</section>
