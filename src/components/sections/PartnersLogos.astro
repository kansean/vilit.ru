---
import Container from '../ui/Container.astro';
import { partners } from '../../data/partners';
---

<section class="py-12 bg-neutral-50">
  <Container>
    <div class="text-center mb-8">
      <h2 class="text-lg font-semibold text-neutral-500 uppercase tracking-wide">Наши партнёры</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-8 items-center">
      {partners.map((partner) => (
        <div class="flex items-center justify-center h-12 grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-200" title={partner.name}>
          <img src={partner.logo} alt={partner.name} class="max-h-full max-w-full" width="160" height="48" loading="lazy" />
        </div>
      ))}
    </div>
  </Container>
</section>
