---
import Container from '../ui/Container.astro';

const testimonials = [
  {
    name: 'Алексей Петров',
    company: 'Продуктовый магазин «Берёзка»',
    text: 'Обратились за кассой и ОФД. Ребята подобрали оптимальный вариант, всё настроили за день. Уже год работаем без проблем, а если что — поддержка отвечает быстро.',
    rating: 5,
  },
  {
    name: 'Мария Иванова',
    company: 'Кофейня «Зерно»',
    text: 'Открывали кофейню и не знали, с чего начать по кассам. Вилит помогли с выбором компактной кассы, подключили ОФД и маркировку молочки. Очень довольна сервисом!',
    rating: 5,
  },
  {
    name: 'Дмитрий Сидоров',
    company: 'Пивной магазин «Хмель»',
    text: 'ЕГАИС — это головная боль, но с Вилит всё прошло гладко. Подключили, настроили сканер акцизных марок, обучили продавцов. Работаем уже полгода без штрафов.',
    rating: 5,
  },
];
---

<section class="section bg-neutral-50" id="testimonials">
  <Container>
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900 mb-4">Отзывы клиентов</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Что говорят о нас предприниматели, которые уже работают с нашим оборудованием
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl shadow-sm border border-neutral-100 p-6">
          <div class="flex items-center gap-1 mb-4">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-neutral-700 mb-4 leading-relaxed">«{t.text}»</p>
          <div>
            <div class="font-semibold text-neutral-900">{t.name}</div>
            <div class="text-sm text-neutral-500">{t.company}</div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
