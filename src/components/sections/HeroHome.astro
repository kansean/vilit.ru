---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
---

<section class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/10 rounded-full translate-y-1/3 -translate-x-1/4"></div>
  </div>

  <Container>
    <div class="relative py-20 lg:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-4 py-2 text-sm font-medium mb-6 backdrop-blur-sm">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          Работаем по всей России
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Автоматизация <br class="hidden sm:block" />
          <span class="text-primary-300">розничной торговли</span>
        </h1>

        <p class="text-lg sm:text-xl text-primary-100 mb-8 max-w-2xl leading-relaxed">
          Онлайн-кассы, ОФД, маркировка, ЕГАИС, ЭЦП — всё для законной работы вашего бизнеса.
          Поставка оборудования, подключение сервисов, регистрация в ФНС под ключ.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button variant="secondary" size="lg" data-callback>
            Получить консультацию
          </Button>
          <Button variant="outline" size="lg" href="/uslugi" class="border-white/30 text-white hover:bg-white/10">
            Наши услуги
          </Button>
        </div>

        <div class="mt-12 flex flex-wrap gap-8 text-sm text-primary-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Официальный дилер
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Гарантия на оборудование
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Настройка под ключ
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
